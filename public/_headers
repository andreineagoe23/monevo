/*
  # Prevent clickjacking
  X-Frame-Options: DENY

  # Stop MIME-type sniffing
  X-Content-Type-Options: nosniff

  # Force HTTPS for 1 year, include subdomains
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Disable referrer for cross-origin requests
  Referrer-Policy: strict-origin-when-cross-origin

  # Restrict browser features not needed by the site
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()

  # Content Security Policy
  # - default: only same origin
  # - scripts: self + module scripts
  # - styles: self + fontshare
  # - fonts: self + fontshare + gstatic
  # - connect: self (form submissions, analytics)
  # - frame: none
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://api.fontshare.com; font-src 'self' https://api.fontshare.com https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://formspree.io; frame-src 'none'; object-src 'none'; base-uri 'self';
